{
  "name": "bicom-pisek-web",
  "version": "1.0.0",
  "description": "Frontend prototyp pro Bicom Pisek s pripravenym Tailwind build pipeline.",
  "scripts": {
    "build:css": "tailwindcss -i ./src/input.css -o ./public/css/styles.css --minify",
    "watch:css": "tailwindcss -i ./src/input.css -o ./public/css/styles.css --watch",
    "build": "npm run build:css",
    "cf:dev": "npm run build && wrangler pages dev public --compatibility-date=2026-04-28",
    "cf:deploy": "npm run build && wrangler pages deploy public --project-name bicom-pisek"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MEVERIK-SOLUTION/Bicom-Pisek-web.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/MEVERIK-SOLUTION/Bicom-Pisek-web/issues"
  },
  "homepage": "https://github.com/MEVERIK-SOLUTION/Bicom-Pisek-web#readme",
  "devDependencies": {
    "tailwindcss": "^3.4.17",
    "wrangler": "^4.13.2"
  }
}
